{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0a0a1790",
                "editor.background": "#0a0a1790",
                "editor.foreground": "#c1c1c5",
                "text": "#c1c1c5",
                "text.muted": "#c1c1c570",
                "text.ignored": "#c1c1c540",
                "text.placeholder": "#c1c1c550",
                "ignored": "#c1c1c530",
                "element.hover": "#c1c1c530",
                "ghost_element.hover": "#eaa99a30",
                "ghost_element.selected": "#eaa99a30",
                "ghost_element.active": "#eaa99a60",
                "border": "#0a0a17",
                "editor.highlighted_line.background": "#eaa99a10",
                "editor.active_line.background": "#eaa99a10",
                "panel.background": "#0a0a1790",
                "title_bar.background": "#0a0a1790",
                "title_bar.inactive_background": "#0a0a1790",
                "status_bar.background": "#0a0a1790",
                "drop_target.background": "#0a0a1790",
                "elevated_surface.background": "#0a0a17",
                "toolbar.background": "#0a0a1790",
                "tab_bar.background": "#0a0a1790",
                "tab.inactive_background": "#0a0a1790",
                "tab.active_background": "#eaa99a30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0a0a17",
                "scrollbar.thumb.background": "#eaa99a",
                "editor.gutter.background": "#0a0a1790",
                "terminal.background": "#0a0a1710",
                "terminal.foreground": "#c1c1c5",
                "terminal.dim_foreground": "#c1c1c5",
                "terminal.bright_foreground": "#c1c1c5",
                "terminal.ansi.black": "#0a0a17",
                "terminal.ansi.red": "#eaa99a",
                "terminal.ansi.green": "#8ec3d0",
                "terminal.ansi.yellow": "#d7b7a9",
                "terminal.ansi.blue": "#a0c5a2",
                "terminal.ansi.magenta": "#cfc3a1",
                "terminal.ansi.cyan": "#ce9aa9",
                "terminal.ansi.white": "#c1c1c5",
                "terminal.ansi.bright_black": "#59596d",
                "terminal.ansi.bright_red": "#eaa99a",
                "terminal.ansi.bright_green": "#8ec3d0",
                "terminal.ansi.bright_yellow": "#d7b7a9",
                "terminal.ansi.bright_blue": "#a0c5a2",
                "terminal.ansi.bright_magenta": "#cfc3a1",
                "terminal.ansi.bright_cyan": "#ce9aa9",
                "terminal.ansi.bright_white": "#c1c1c5",
                "modified": "#eaa99a",
                "syntax": {
                    "attribute": {
                        "color": "#eaa99a"
                    },
                    "boolean": {
                      "color": "#8ec3d0"
                    },
                    "comment": {
                      "color": "#59596d"
                    },
                    "comment.doc": {
                      "color": "#59596d"
                    },
                    "constant": {
                      "color": "#8ec3d0"
                    },
                    "function": {
                      "color": "#ce9aa9"
                    },
                    "keyword": {
                      "color": "#a0c5a2"
                    },
                    "number": {
                      "color": "#cfc3a1"
                    },
                    "operator": {
                      "color": "#a0c5a2"
                    },
                    "string": {
                      "color": "#eaa99a"
                    },
                    "variable": {
                      "color": "#8ec3d0"
                    }
                },
                "players": [
                  {
                    "cursor": "#eaa99a",
                    "background": "#0a0a17",
                    "selection": "#eaa99a30"
                  }
                ]
            }
        }
    ]
}
